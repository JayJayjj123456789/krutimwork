# Server
PORT=3000                         # Backend server port (default: 3000)

# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co   # Your Supabase project URL
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_KEY          # Supabase service_role key (keep secret!)

# OpenWeatherMap (free tier)
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY    # https://openweathermap.org/api

# Typhoon AI (LLM for health analysis)
TYPHOON_API_KEY=YOUR_TYPHOON_API_KEY            # https://opentyphoon.ai
TYPHOON_API_URL=https://api.opentyphoon.ai/v1/chat/completions
