# Server
PORT=3000

# CORS — comma-separated list of allowed origins
# Firebase Hosting (*.web.app, *.firebaseapp.com) is auto-allowed.
# Add custom domains or extra origins here.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Firebase (Firestore + Auth Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
# Provide either FIREBASE_SERVICE_ACCOUNT (JSON string) OR place service-account.json in backend/
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Typhoon AI (LLM for health analysis + chat)
TYPHOON_API_KEY=YOUR_TYPHOON_API_KEY
TYPHOON_API_URL=https://api.opentyphoon.ai/v1/chat/completions

# Tavily (web search for AI chat)
TAVILY_API_KEY=YOUR_TAVILY_API_KEY
